{% block manufacturer_page_header %}
    {% set manufacturer = page.manufacturer %}

    <div class="cms-element-manufacturer-header">
        {% block manufacturer_page_header_banner %}
            <div
                    class="moorl-manufacturer-banner"
                    {% if manufacturer.bannerColor %}style="background-color:{{ manufacturer.bannerColor }}"{% endif %}
            >
                {% if manufacturer.banner %}
                    {% sw_thumbnails 'manufacturer-banner' with {
                        media: manufacturer.banner,
                        attributes: {
                            'class': '',
                            'alt': manufacturer.translated.name,
                            'title': manufacturer.translated.name
                        }
                    } %}
                {% endif %}
            </div>
        {% endblock %}

        {% block manufacturer_page_header_container %}
            <div class="container p-0">
                <div class="row">
                    {% block manufacturer_page_header_avatar %}
                        {% if manufacturer.avatar or manufacturer.productManufacturer.media %}
                            <div class="col-auto">
                                <div class="moorl-manufacturer-avatar">
                                    {% sw_thumbnails 'manufacturer-avatar' with {
                                        media: manufacturer.avatar ?: manufacturer.productManufacturer.media,
                                        attributes: {
                                            'itemprop': 'image',
                                            'class': '',
                                            'alt': manufacturer.translated.name,
                                            'title': manufacturer.translated.name
                                        }
                                    } %}
                                </div>
                            </div>
                        {% endif %}
                    {% endblock %}
                    <div class="col">
                        {% block manufacturer_page_header_title %}
                            <h1 class="moorl-manufacturer-title">
                                <span itemprop="name">{{ manufacturer.translated.name }}</span>
                            </h1>
                            <p>
                                <small>{{ manufacturer.productCount }} {{ "moorl-manufacturer.products"|trans }}</small>
                            </p>
                        {% endblock %}

                        {% block manufacturer_page_header_description %}
                            <div itemprop="description" class="moorl-manufacturer-description">
                                {{ manufacturer.translated.teaser }}
                            </div>
                        {% endblock %}

                        {% block manufacturer_page_header_actions %}
                            <div class="moorl-manufacturer-actions">
                                {% if manufacturer.merchantUrl %}
                                    <a
                                            class="btn btn-secondary"
                                            href="{{ manufacturer.merchantUrl }}"
                                            title="{{ "moorl-manufacturer.link"|trans }}"
                                            rel="noopener"
                                            target="_blank"
                                    >
                                        {{ "moorl-manufacturer.link"|trans }}
                                    </a>
                                {% endif %}
                            </div>
                        {% endblock %}
                    </div>
                </div>
            </div>
        {% endblock %}
    </div>
{% endblock %}
