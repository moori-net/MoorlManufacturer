{
    "name": "moorl/manufacturer",
    "description": "Extended Manufacturer",
    "version": "1.7.0",
    "license": "proprietary",
    "authors": [
        {
            "name": "moori"
        }
    ],
    "require": {
        "shopware/core": "~6.7.0",
        "moorl/foundation": "~1.7.46"
